# LillyCam configuration
# Copy this to .env and adjust values for your setup.
# All settings have sensible defaults - only override what you need.

# --- Model profile ---
# Which hardware variant this build is. Selects sensible per-model defaults;
# any specific setting below still overrides the profile.
#   standard = Pi Zero W v1.1 + Camera Module v2  (640x480@15, OLED_FPS 6)
#   pro      = Pi Zero 2 W    + Camera Module 3   (1280x720@30, OLED_FPS 12)
LILLYCAM_MODEL=standard

# --- Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Camera ---
CAMERA_AUTOSTART=false  # camera is off at boot for privacy; turn it on from the web UI
CAMERA_SOUND=true       # play a chirp through the speaker when the camera turns on
# Stream resolution/fps default from LILLYCAM_MODEL (standard 640x480@15, pro 1280x720@30).
# Uncomment to override for your specific build:
# STREAM_WIDTH=640
# STREAM_HEIGHT=480
# STREAM_FPS=15
STILL_WIDTH=3280
STILL_HEIGHT=2464
CAPTURE_DIR=/home/admin/captures

# --- Stepper ---
# 28BYJ-48: 2048 full-steps/rev on output shaft. Tune to your funnel geometry.
STEPPER_STEPS_PER_DISPENSE=700
STEPPER_STEP_DELAY=0.002

# --- Servo ---
SERVO_MIN_ANGLE=0
SERVO_MAX_ANGLE=180
SERVO_DEFAULT_ANGLE=90
# Hardware PWM (rpi-hardware-pwm). GPIO 12 = channel 0; needs dtoverlay=pwm,pin=12,func=4.
# chip is 0 on Pi Zero / Zero 2 W / Pi 4, 2 on Pi 5. Uncomment to override:
# SERVO_PWM_CHANNEL=0
# SERVO_PWM_CHIP=0
# SERVO_PWM_FREQ=50

# --- Audio ---
AUDIO_ENABLED=true
AUDIO_SAMPLE_RATE=48000  # googlevoicehat I2S driver requires 48000
AUDIO_CHANNELS=1
AUDIO_RECORD_SECONDS=5
AUDIO_PLAYBACK_GAIN=2.0  # linear gain before playback (1.0 = unity, 2.0 = ~6dB boost)

# --- TLS (required for push-to-talk microphone) ---
# Get certs: sudo tailscale cert <your-tailscale-hostname>
# Then chown to admin so the service can read them.
# TAILSCALE_CERT=/home/admin/lillycam/lillycam.tailXXXXX.ts.net.crt
# TAILSCALE_KEY=/home/admin/lillycam/lillycam.tailXXXXX.ts.net.key

# --- Control lock ---
# Only one device controls LillyCam at a time. If the controller stops sending
# heartbeats (tab closed) for this many seconds, the slot auto-releases.
CONTROL_TIMEOUT=15.0
# Turn the camera off automatically when the last controller disconnects.
CAMERA_OFF_ON_IDLE=true

# --- OLED ---
OLED_WIDTH=128
OLED_HEIGHT=32
OLED_ANIMATE=true  # animated cat face (sleeps when camera off, wakes when on); false = static text
# OLED_FPS defaults from LILLYCAM_MODEL (standard 6, pro 12). Uncomment to override:
# OLED_FPS=6

# --- PWA / Web Push (experimental) ---
# The web UI installs to the iOS/Android home screen (manifest + icons).
# PWA_ENABLED only adds the manifest + service worker; harmless, on by default.
PWA_ENABLED=true
# Web Push notifications. Opt-in: needs "pip install pywebpush" and HTTPS (the
# TAILSCALE_CERT above). On iOS 16.4+ push only works after Add to Home Screen.
PUSH_ENABLED=false
# VAPID contact ("sub" claim) - use a real mailto you control.
PUSH_CONTACT=mailto:sergio@smarobix.com
# Where VAPID keys + push subscriptions are stored (default ~/.lillycam).
# PUSH_STATE_DIR=/home/admin/.lillycam
